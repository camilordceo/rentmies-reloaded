# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Callbell
CALLBELL_API_KEY=your_callbell_api_key_here

# Rentmies Responses API
RENTMIES_RESPONSES_URL=https://rentmiesresponses.azurewebsites.net/api/rentmies/responses

# Azure OpenAI (embeddings for vector property search)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-02-01

# WhaRentmies — Wassenger WhatsApp provider (wzap.chat)
WHARENTMIES_API_TOKEN=         # Wassenger API token (Token header, not Bearer)
WHARENTMIES_DEVICE_ID=         # Wassenger device/session ID
WHARENTMIES_WEBHOOK_SECRET=    # HMAC-SHA256 secret for webhook signature validation

# WhatsApp provider routing
WHATSAPP_DEFAULT_PROVIDER=callbell   # 'callbell' or 'wharentmies'

# Portal public search (assistant_id for /inmuebles public portal)
PORTAL_ASSISTANT_ID=
